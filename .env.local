# 本地开发 .env.local；Vercel 在项目 Environment Variables 中配置同名变量。

OPENAI_API_KEY=

# 可选：留空则默认 https://api.openai.com/v1
# OPENAI_API_BASE=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# --- 阿里云百炼（DashScope OpenAI 兼容模式）---
# 控制台创建 API-Key 后填入 OPENAI_API_KEY；BASE 使用兼容端点（勿在末尾多加 /v1 重复拼接）。
OPENAI_API_BASE=
OPENAI_MODEL=
# 如果你用的是阿里百炼兼容模式
# OPENAI_API_KEY=你的百炼key
# OPENAI_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
# OPENAI_MODEL=qwen3.5-flash